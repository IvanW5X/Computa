# Target path on the Pi: /etc/openclaw/secrets.env
#
# Owner pi:pi, mode 0640. Read by:
#   /etc/systemd/system/ollama.service.d/override.conf  (no, Ollama needs no secrets)
#   /etc/systemd/system/computa-router.service          (NVIDIA_API_KEY)
#   /etc/systemd/system/ai-dashboard.service            (none required, kept
#                                                        consistent so the
#                                                        same EnvironmentFile
#                                                        works everywhere)
#   OpenClaw process (DISCORD_BOT_TOKEN, OPENCLAW_GATEWAY_PASSWORD,
#                     and NVIDIA_API_KEY for the NIM model provider)
#
# IMPORTANT
#   - No quotes around values. systemd EnvironmentFile parses them literally.
#   - One KEY=VALUE per line. Lines starting with "#" are comments.
#   - chmod 0640 /etc/openclaw/secrets.env  (root-readable, pi-readable, world-blind)
#   - chown root:pi /etc/openclaw/secrets.env

# -------------------------------------------------------------------
# NVIDIA_API_KEY
# -------------------------------------------------------------------
# Where to get it:
#   1. https://build.nvidia.com/  -> Login (free NVIDIA developer account).
#   2. Click any model card (for example
#      https://build.nvidia.com/nvidia/nemotron-3-super-120b-a12b ).
#   3. Click "Get API Key" in the right panel. The key starts with `nvapi-`.
# Permissions / quota:
#   - Free tier currently grants several thousand request credits for
#     development. There is no scoped permission set you have to enable;
#     the key is bearer-token style and works against every NIM model your
#     account can access.
#   - The key has FULL ACCESS to your NVIDIA build account's NIM quota.
#     Treat it the same as a payment credential.
NVIDIA_API_KEY=nvapi-REPLACE_ME

# -------------------------------------------------------------------
# DISCORD_BOT_TOKEN
# -------------------------------------------------------------------
# Where to get it:
#   1. https://discord.com/developers/applications -> "New Application".
#   2. Sidebar -> "Bot" -> "Reset Token" -> copy the secret. You only see
#      it once. If you lose it, rotate -- it cannot be retrieved.
# Required intents (Bot tab -> Privileged Gateway Intents):
#   - Message Content Intent  : ON  (REQUIRED -- without this, the bot
#                                    cannot read the text of @-mentions,
#                                    only metadata.)
#   - Server Members Intent   : optional, only needed if a skill ever
#                                resolves @user mentions to display names.
#   - Presence Intent         : OFF (not needed)
# OAuth2 -> URL Generator scopes/permissions when inviting:
#   - Scopes      : bot, applications.commands
#   - Permissions : Send Messages, Read Message History,
#                   Create Public Threads, Send Messages in Threads
DISCORD_BOT_TOKEN=REPLACE_ME

# -------------------------------------------------------------------
# OPENCLAW_GATEWAY_PASSWORD
# -------------------------------------------------------------------
# Why it exists:
#   We set gateway.bind = "lan" (0.0.0.0) so the Control UI is reachable
#   on the LAN. The OpenClaw docs explicitly require auth on every
#   non-loopback bind, so gateway.auth.mode must be "password" or "token".
#   This password is referenced in openclaw.json via ${OPENCLAW_GATEWAY_PASSWORD}.
#
# Pick a strong value:
#   openssl rand -base64 32
#
# This password lets ANYONE on your LAN open the OpenClaw Control UI, view
# transcripts, and edit config. Do not reuse a password from elsewhere.
OPENCLAW_GATEWAY_PASSWORD=REPLACE_ME_with_openssl_rand_base64_32

# -------------------------------------------------------------------
# (Optional) DASHBOARD_BASIC_AUTH
# -------------------------------------------------------------------
# Not used by server.py as shipped. The dashboard binds to 0.0.0.0:3000
# with no auth. If you put the Pi on an untrusted network, either firewall
# port 3000 to your LAN subnet or front it with caddy/nginx + basic auth.
# Documented here so future-you remembers it is intentionally absent.
# DASHBOARD_BASIC_AUTH=
