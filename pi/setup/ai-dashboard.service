# Target path on the Pi: /etc/systemd/system/ai-dashboard.service
#
# Runs the metrics dashboard on port 3000 as the yelopi user, alongside
# the existing ai-router.service / openclaw-gateway.service. Stdlib-only
# Python -- no venv, no pip, no npm. Reads the router's shared .env so
# any router-side variables (NVIDIA_API_KEY, OLLAMA_BASE, ROUTER_DB_PATH)
# stay in one place.

[Unit]
Description=AI metrics dashboard for the hybrid Pi gateway (port 3000)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
User=yelopi
Group=yelopi

# `-` prefix: do not fail to start if the .env is missing or empty.
EnvironmentFile=-/home/yelopi/router/.env

# Hard defaults so the service still works without the .env file.
Environment=PYTHONUNBUFFERED=1
Environment=ROUTER_DB_PATH=/home/yelopi/dashboard/requests.db

WorkingDirectory=/home/yelopi/dashboard
ExecStart=/usr/bin/python3 /home/yelopi/dashboard/server.py

Restart=on-failure
RestartSec=5s

# Resource caps so the dashboard never competes with Ollama for RAM.
MemoryHigh=64M
MemoryMax=96M
CPUQuota=40%
Nice=10

# Light filesystem hardening. SQLite WAL mode requires the reader to write
# the .db-shm / .db-wal sidecar files even for "read-only" connections, so
# we punch a writable hole for the dashboard directory only -- nothing else
# on the filesystem is writable from this unit.
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/yelopi/dashboard
PrivateTmp=true
NoNewPrivileges=true
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
