# ============================================================
# .env.example
# ============================================================
# Role: Tier 2 — Orchestration (configuration template)
# Purpose: Safe-to-commit template showing which environment
#          variables the bot requires at runtime. Copy this to
#          .env and replace each placeholder with a real secret.
# Calls:   none
# Used by: src/index.js (DISCORD_BOT_TOKEN via dotenv),
#          skills/escalate_to_nim.py (NVIDIA_API_KEY).
# ============================================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
NVIDIA_API_KEY=your_nvidia_api_key_here
